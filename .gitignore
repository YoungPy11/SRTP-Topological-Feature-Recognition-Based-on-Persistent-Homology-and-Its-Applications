# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
venv/
env/
.venv/

# Jupyter Notebook checkpoint
.ipynb_checkpoints/

# Distribution / packaging
dist/
build/
*.egg-info/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# LaTeX build artifacts (keep source, ignore intermediates)
*.aux
*.log
*.out
*.toc
*.synctex.gz
*.fls
*.fdb_latexmk
*.snm

# Large data files
data/*.npy
data/*.pkl
data/*.csv

# Results (optional: uncomment to ignore)
# results/*.png
# results/*.pdf
